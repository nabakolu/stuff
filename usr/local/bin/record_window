#!/bin/bash

echo "Select audio source (monitor):"
mapfile -t SOURCES < <(pactl list sources short | awk '{print $2}')

select SRC in "${SOURCES[@]}"; do
    if [[ -n "$SRC" ]]; then
        echo "Using audio source: $SRC"
        break
    else
        echo "Invalid selection"
    fi
done

echo "Click the window you want to record..."
eval $(xwininfo | awk '
/Absolute upper-left X/ {x=$4}
/Absolute upper-left Y/ {y=$4}
/Width/ {w=$2}
/Height/ {h=$2}
END {printf "X=%d Y=%d W=%d H=%d", x, y, w, h}
')

ffmpeg -f x11grab -framerate 60 -video_size ${W}x${H} -i :0.0+${X},${Y} \
       -f pulse -i "$SRC" \
       -c:v libx264 -preset veryfast -crf 23 \
       -c:a aac -b:a 192k \
       "$(date +%F_%H-%M-%S).mkv"
